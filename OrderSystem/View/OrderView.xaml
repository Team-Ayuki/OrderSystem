<UserControl x:Class="OrderSystem.View.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OrderSystem.View"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000" Background="Beige">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- 左側の画面-->
        <!--大分類カテゴリーのボタン群-->
        <ItemsControl ItemsSource="{Binding BigCategories}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Name}" Width="110" Height="60" Margin="5,0,0,0" FontSize="24"
                            Command="{Binding DataContext.BigCategoryCommand,
                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                            CommandParameter="{Binding}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!--中分類カテゴリーのボタン群-->
        <ItemsControl ItemsSource="{Binding MidCategories}" Grid.Column="0" Grid.Row="1">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Name}" Width="90" Height="60" Margin="5,0,0,0" FontSize="18"
                                Command="{Binding DataContext.MidCategoryCommand,
                                RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                CommandParameter="{Binding}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <DockPanel Grid.Row="2">
            <Button Content="←" DockPanel.Dock="Left" Width="30" Command="{Binding LeftCommand}" Background="LightSlateGray" Foreground="Black"/>
            <Button Content="→" DockPanel.Dock="Right" Width="30" Command="{Binding RightCommand}" Background="LightSlateGray" Foreground="Black"/>
            <!--お寿司の画像ボタンを表示する部分-->
            <ItemsControl ItemsSource="{Binding ViewProducts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" Rows="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="210" Height="150" Margin="5" 
                                Command="{Binding DataContext.ProductCommand,
                                RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                CommandParameter="{Binding}"
>
                            <StackPanel>
                                <Image Source="{Binding imgFilePath}" Width="190" Height="120"/>
                                <TextBlock Text="{Binding name}" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
        <!--左下のボタン群-->
        <StackPanel Grid.Row="3" Grid.ColumnSpan="1" Orientation="Horizontal">
            <Button Content="TOPへ" Width="100" Height="60" Margin="0,0,10,0" Command="{Binding TopCommand}"/>
            <Button Content="注文履歴" Width="100" Height="60" Margin="0,0,0,0" Command="{Binding HistoryCommand}"/>
        </StackPanel>

        <!--右の画面-->
        <!--右上の画像(Sourceを動的に変更)-->
        <Image Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Stretch="Uniform" Source="{Binding SelectedProductFilePath}"/>


        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
            <!--右中央の数変更ボタン群-->
            <StackPanel Orientation="Horizontal" >
                <Button Content="-" Width="30" Height="30" Margin="50,0,0,0" Command="{Binding MinusCommand}" CommandParameter="{Binding SelectedItem}"/>
                <TextBlock Text="{Binding SelectedProductCount}" Width="30" Height="30" TextAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                <Button Content="+" Width="30" Height="30" Command="{Binding PlusCommand}" CommandParameter="{Binding SelectedItem}"/>
            </StackPanel>
            <!--右中央の注文リスト-->
            <Button Content="注文確定" Width="150" Height="60" Margin="0,10,0,0" Command="{Binding OrderCommand}"/>
            <DataGrid ItemsSource="{Binding orderCart}" AutoGenerateColumns="False" Height="240"
                      SelectedItem="{Binding SelectedItem}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="商品名" Binding="{Binding product.name}" Width="2*"/>
                    <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="*"/>
                    <DataGridTemplateColumn Header="削除" Width="50" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="削除" Width="40" Height="20" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!--右下の会計確定ボタン-->
        <Button Grid.Row="3" Grid.Column="1" Content="会計確定" Width="150" Height="60" Command="{Binding CheckOutCommand}"/>


    </Grid>
</UserControl>
